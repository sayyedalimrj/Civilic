// ═══════════════════════════════════════════════════════════
//  موتور کارتابل و تأییدات (Workflow Engine)
// ═══════════════════════════════════════════════════════════

model WorkflowTemplate {
  id              String   @id @default(cuid())
  code            String   @unique // PAYMENT_STATEMENT | ADJUSTMENT | MINUTES | WORK_ORDER
  title           String
  createdAt       DateTime @default(now())

  steps           ApprovalStep[]
}

model WorkflowInstance {
  id              String   @id @default(cuid())
  projectId       String
  templateCode    String
  entityType      String   // PAYMENT | ADJUSTMENT | METERING
  entityId        String
  state           String   @default("DRAFT")
  currentStep     Int      @default(0)
  createdById     String
  createdByName   String
  lockedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actions         WorkflowAction[]

  @@index([projectId])
  @@index([entityType, entityId])
}

model WorkflowAction {
  id              String   @id @default(cuid())
  instanceId      String
  actorId         String
  actorName       String
  actorPartyType  String   // EMPLOYER | CONSULTANT | CONTRACTOR
  action          String   // SUBMIT | REVIEW | APPROVE | RETURN | REJECT | LOCK | REOPEN
  note            String?
  attachmentsJson String   @default("[]")
  createdAt       DateTime @default(now())

  instance        WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
}

model ApprovalStep {
  id                  String   @id @default(cuid())
  templateId          String
  stepOrder           Int
  partyType           String   // EMPLOYER | CONSULTANT | CONTRACTOR
  requiredRole        String?
  actionLabel         String
  canEdit             Boolean  @default(false)
  canReturn           Boolean  @default(false)
  canApprove          Boolean  @default(false)

  template            WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

// ═══════════════════════════════════════════════════════════
//  چت، مکاتبات و کامنت‌ها (Communication)
// ═══════════════════════════════════════════════════════════

model ProjectChannel {
  id              String   @id @default(cuid())
  projectId       String
  title           String
  type            String   // GENERAL | TECHNICAL | PAYMENT | ADJUSTMENT | SITE | OFFICIAL | ENTITY_THREAD
  entityType      String?  // PAYMENT | ADJUSTMENT | etc.
  entityId        String?
  visibility      String   @default("ALL_PARTIES") // ALL_PARTIES | EMPLOYER_CONSULTANT | CONSULTANT_CONTRACTOR | INTERNAL_PARTY
  createdAt       DateTime @default(now())

  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members         ChannelMember[]
  messages        Message[]

  @@index([projectId])
  @@index([entityType, entityId])
}

model ChannelMember {
  id          String   @id @default(cuid())
  channelId   String
  userId      String
  role        String   @default("MEMBER") // OWNER | MEMBER | READONLY
  createdAt   DateTime @default(now())

  channel     ProjectChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([channelId])
}

model Message {
  id              String   @id @default(cuid())
  channelId       String
  senderId        String
  senderName      String
  body            String
  attachmentIdsJson String @default("[]")
  replyToId       String?
  createdAt       DateTime @default(now())
  editedAt        DateTime?

  channel         ProjectChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  readReceipts    MessageReadReceipt[]

  @@index([channelId])
  @@index([senderId])
}

model MessageReadReceipt {
  id          String   @id @default(cuid())
  messageId   String
  userId      String
  readAt      DateTime @default(now())

  message     Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

model Letter {
  id              String   @id @default(cuid())
  projectId       String
  fromPartyId     String
  toPartyId       String
  subject         String
  body            String
  letterNo        String?
  letterDate      DateTime?
  status          String   @default("DRAFT") // DRAFT | SENT | RECEIVED | ANSWERED | ARCHIVED
  attachmentIdsJson String @default("[]")
  createdAt       DateTime @default(now())

  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromParty       ProjectParty @relation("LetterFrom", fields: [fromPartyId], references: [id])
  toParty         ProjectParty @relation("LetterTo", fields: [toPartyId], references: [id])

  @@index([projectId])
  @@index([status])
}

model Document {
  id                String   @id @default(cuid())
  projectId         String
  title             String
  type              String   // CONTRACT | DRAWING | MINUTES | WORK_ORDER | PAYMENT | ADJUSTMENT | ATTACHMENT
  entityType        String?
  entityId          String?
  currentVersionId  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  versions          DocumentVersion[]

  @@index([projectId])
  @@index([type])
}

model DocumentVersion {
  id            String   @id @default(cuid())
  documentId    String
  versionNo     Int      @default(1)
  fileUrl       String
  fileName      String
  fileSizeBytes Int      @default(0)
  uploadedById  String?
  uploadedByName String?
  createdAt     DateTime @default(now())

  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}
