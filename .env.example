# ─── Civilic — نمونه‌ی متغیرهای محیطی ───

# (الزامی) PostgreSQL برای production — Prisma Postgres / Supabase / Neon
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/civilic?schema=public"

# (الزامی) احراز هویت Auth.js / NextAuth
#  NEXTAUTH_SECRET: با دستور `openssl rand -base64 32` بسازید
#  NEXTAUTH_URL: آدرس کامل دامنه‌ی deploy (روی Vercel = آدرس production/preview)
NEXTAUTH_SECRET=""
NEXTAUTH_URL="https://app.civilic.ir"

# ─── Bootstrap دموی یک‌باره (فقط preview/دمو) ───
#  برای فعال‌سازی POST /api/bootstrap/demo-seed هر دو لازم‌اند:
ENABLE_DEMO_BOOTSTRAP="false"   # روی preview = "true"
BOOTSTRAP_SECRET=""             # یک رشته‌ی تصادفی قوی

# ─── آپلود فایل (production) ───
UPLOAD_PROVIDER="local"         # local | vercel-blob | s3 | r2
BLOB_READ_WRITE_TOKEN=""

# ─── حالت import تکسا ───
#  local = خواندن فایل .svzt از workspace (dev)
#  preview = فقط داده‌ی seed نرمال‌شده (بدون parse فایل بزرگ)
#  production = آپلود مستقیم به storage + job پردازش
TEXSA_IMPORT_MODE="preview"

NODE_ENV="development"
