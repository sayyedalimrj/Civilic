# ─── Civilic — نمونه‌ی متغیرهای محیطی ───
# برای production از PostgreSQL استفاده کنید (Prisma Postgres / Supabase / Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/civilic?schema=public"

# احراز هویت (Auth.js / NextAuth)
NEXTAUTH_SECRET="" # با: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"

# آپلود فایل (production): vercel-blob | s3 | r2 | local
UPLOAD_PROVIDER="local"
BLOB_READ_WRITE_TOKEN=""

# حالت import تکسا: local | preview | production
#  local      = خواندن فایل .svzt از workspace (dev)
#  preview    = فقط داده‌ی seed نرمال‌شده (بدون parse فایل بزرگ)
#  production = آپلود مستقیم به storage + job پردازش
TEXSA_IMPORT_MODE="preview"

NODE_ENV="development"
